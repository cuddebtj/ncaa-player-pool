# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Note: Special characters in password must be URL-encoded:
#   / → %2F
#   @ → %40
#   : → %3A
#   = → %3D
#   # → %23
#   ? → %3F
#   % → %25
#   & → %26
#   + → %2B
#   space → %20
POSTGRES_CONN_STR=postgresql://ncaa_pool_app:your_encoded_password@postgres.cuddelabs.com:5432/cuddelabs

# Optional: Override schema name (default: ncaa_pool)
DATABASE_SCHEMA=ncaa_pool

# Optional: Tournament year (default: 2026)
TOURNAMENT_YEAR=2026

# Optional: Log level (default: INFO)
LOG_LEVEL=INFO

# Optional: Log file path (default: logs/ncaa_pool.log)
LOG_FILE=logs/ncaa_pool.log

# Google Sheets Integration (Required for export command)
# 1. Create a service account in Google Cloud Console
# 2. Download the JSON credentials file
# 3. Share your Google Sheet with the service account email
# 4. Get the Sheet ID from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_CREDENTIALS_FILE=path/to/service-account-credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id_here
